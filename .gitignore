# .gitignore

# ================= СЕКРЕТЫ =================
.env
*.env
secrets.json
config.ini
*.key
*.pem

# ================= PYTHON =================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# ================= ВИРТУАЛЬНОЕ ОКРУЖЕНИЕ =================
venv/
env/
.venv/
ENV/

# ================= IDE / РЕДАКТОРЫ =================
.idea/
.vscode/
*.swp
*.swo
*~

# ================= ЛОГИ И ВРЕМЕННЫЕ ФАЙЛЫ =================
*.log
logs/
tmp/
temp/
*.tmp

# ================= БАЗЫ ДАННЫХ =================
*.db
*.sqlite3

# ================= СИСТЕМНЫЕ ФАЙЛЫ =================
.DS_Store
Thumbs.db

